{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vorec.ai/schemas/live-site-map.schema.json",
  "title": "Vorec live site map",
  "type": "object",
  "additionalProperties": true,
  "required": ["url", "recording_type", "goal", "auth", "pages", "blockers", "sensitive_actions", "readiness"],
  "properties": {
    "url": {
      "type": "string",
      "minLength": 1
    },
    "recording_type": {
      "type": "string",
      "enum": ["task_tutorial", "website_tour", "bug_reproduction", "ux_review"]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "auth": {
      "type": "object",
      "additionalProperties": true,
      "required": ["required", "evidence"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["url", "purpose"],
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "headings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["label", "role", "selector", "result"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "minLength": 1 },
                "selector": { "type": "string", "minLength": 1 },
                "result": { "type": "string", "minLength": 1 },
                "primary": { "type": "boolean" }
              }
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["label", "selector", "required", "valid_demo_value", "evidence"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "selector": { "type": "string", "minLength": 1 },
                "required": {
                  "oneOf": [
                    { "type": "boolean" },
                    { "type": "string", "enum": ["unknown"] }
                  ]
                },
                "type": { "type": "string" },
                "placeholder": { "type": ["string", "null"] },
                "min": { "type": ["string", "number", "null"] },
                "max": { "type": ["string", "number", "null"] },
                "pattern": { "type": ["string", "null"] },
                "valid_demo_value": { "type": ["string", "number", "boolean", "null"] },
                "validation_errors": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "evidence": { "type": "string", "minLength": 1 }
              }
            }
          },
          "buttons": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["label", "selector", "initial_state"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "selector": { "type": "string", "minLength": 1 },
                "initial_state": { "type": "string", "minLength": 1 },
                "enabled_when": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "primary": { "type": "boolean" }
              }
            }
          },
          "success_state": {
            "type": "object",
            "additionalProperties": true,
            "required": ["selector", "evidence"],
            "properties": {
              "selector": { "type": "string", "minLength": 1 },
              "evidence": { "type": "string", "minLength": 1 }
            }
          },
          "risks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sensitive_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_action_known",
        "required_fields_known",
        "valid_demo_values_known",
        "primary_buttons_known",
        "success_state_known",
        "blockers_reviewed",
        "sensitive_actions_reviewed"
      ],
      "properties": {
        "entry_action_known": { "type": "boolean" },
        "required_fields_known": { "type": "boolean" },
        "valid_demo_values_known": { "type": "boolean" },
        "primary_buttons_known": { "type": "boolean" },
        "success_state_known": { "type": "boolean" },
        "blockers_reviewed": { "type": "boolean" },
        "sensitive_actions_reviewed": { "type": "boolean" }
      }
    }
  }
}
